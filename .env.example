# ─────────────────────────────────────────────────────────────────────────────
# Unify API
# ─────────────────────────────────────────────────────────────────────────────
UNIFY_KEY=
UNIFY_BASE_URL="https://api.unify.ai/v0"
UNIFY_CACHE=true

# ─────────────────────────────────────────────────────────────────────────────
# Tests
# ─────────────────────────────────────────────────────────────────────────────
LOCAL_ORCHESTRA_BRANCH="staging"
UNIFY_DELETE_CONTEXT_ON_EXIT=false
UNIFY_OVERWRITE_PROJECT=false
UNIFY_REGISTER_SUMMARY_CALLBACKS=false
UNIFY_REGISTER_UPDATE_CALLBACKS=false
UNIFY_TESTS_RAND_PROJ=false
UNIFY_TESTS_DELETE_PROJ_ON_START=true
UNIFY_TESTS_DELETE_PROJ_ON_EXIT=false
UNIFY_CACHE_BENCHMARK=false
UNIFY_PRETEST_CONTEXT_CREATE=false

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
ASYNCIO_DEBUG=0
ASYNCIO_VERBOSE_DEBUG=0
LLM_IO_DEBUG=1
PYTEST_LOG_TO_FILE=1

# ─────────────────────────────────────────────────────────────────────────────
# LLM Providers
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
VERTEXAI_LOCATION=
VERTEXAI_PROJECT=

# ─────────────────────────────────────────────────────────────────────────────
# Session Details (runtime - populated by StartupEvent in production)
# ─────────────────────────────────────────────────────────────────────────────

# Assistant
ASSISTANT_ID=
ASSISTANT_NAME=
ASSISTANT_AGE=
ASSISTANT_NATIONALITY=
ASSISTANT_ABOUT=
ASSISTANT_NUMBER=
ASSISTANT_EMAIL=

# User
USER_NAME=
USER_NUMBER=
USER_EMAIL=

# Voice
VOICE_PROVIDER=
VOICE_ID=
VOICE_MODE=

# ─────────────────────────────────────────────────────────────────────────────
# Unity
# ─────────────────────────────────────────────────────────────────────────────
UNITY_COMMS_URL=
UNITY_VALIDATE_LLM_PROVIDERS=true

# ─────────────────────────────────────────────────────────────────────────────
# LiveKit (Voice Calls)
# ─────────────────────────────────────────────────────────────────────────────
LIVEKIT_SIP_URI=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Third-Party APIs
# ─────────────────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
TAVILY_API_KEY=
