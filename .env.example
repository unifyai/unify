# Copy this file to `.env` for the smallest public sandbox setup.
# For local comms, hosted comms, voice integrations, Tavily, test infra, and
# visual-cache settings, start from `.env.advanced.example` instead.

# Your Unify API key.
UNIFY_KEY=

# At least one provider key is required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Backend API endpoint. The default points at the hosted platform; the installer
# rewrites this to your local Orchestra when you use the default open-core path.
ORCHESTRA_URL="https://api.unify.ai/v0"

# Auto-shutdown timeout for local Orchestra started by `unity setup`.
ORCHESTRA_INACTIVITY_TIMEOUT_SECONDS=600

# Validate that an LLM provider key is present on startup.
UNITY_VALIDATE_LLM_PROVIDERS=true

# Cache LLM responses locally. First run hits the provider; later runs replay.
UNILLM_CACHE=true
