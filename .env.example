# ─────────────────────────────────────────────────────────────────────────────
# Unify API
# ─────────────────────────────────────────────────────────────────────────────
UNIFY_KEY=
ORCHESTRA_URL="https://api.unify.ai/v0"
UNIFY_CACHE=true

# ─────────────────────────────────────────────────────────────────────────────
# Tests
# ─────────────────────────────────────────────────────────────────────────────
LOCAL_ORCHESTRA_BRANCH="staging"
ORCHESTRA_INACTIVITY_TIMEOUT_SECONDS=600
UNIFY_DELETE_CONTEXT_ON_EXIT=false
UNIFY_OVERWRITE_PROJECT=false
UNIFY_REGISTER_SUMMARY_CALLBACKS=false
UNIFY_REGISTER_UPDATE_CALLBACKS=false
UNIFY_TESTS_RAND_PROJ=false
UNIFY_TESTS_DELETE_PROJ_ON_START=true
UNIFY_TESTS_DELETE_PROJ_ON_EXIT=false
UNIFY_CACHE_BENCHMARK=false
UNIFY_PRETEST_CONTEXT_CREATE=false

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
# Master logging switches (console + file if LOG_DIR is set)
UNITY_LOG=true
UNIFY_LOG=true
UNILLM_LOG=true

# File output directories (set to enable file logging)
# UNITY_LOG_DIR=
# UNIFY_LOG_DIR=
# UNILLM_LOG_DIR=

# Other logging settings
ASYNCIO_DEBUG=0
ASYNCIO_VERBOSE_DEBUG=0
PYTEST_LOG_TO_FILE=1

# ─────────────────────────────────────────────────────────────────────────────
# LLM Providers
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Session Details (runtime - populated by StartupEvent in production)
# ─────────────────────────────────────────────────────────────────────────────

# Assistant
ASSISTANT_ID=
ASSISTANT_NAME=
ASSISTANT_AGE=
ASSISTANT_NATIONALITY=
ASSISTANT_ABOUT=
ASSISTANT_NUMBER=
ASSISTANT_EMAIL=

# User
USER_NAME=
USER_NUMBER=
USER_EMAIL=

# Voice
VOICE_PROVIDER=
VOICE_ID=
VOICE_MODE=

# ─────────────────────────────────────────────────────────────────────────────
# Unity
# ─────────────────────────────────────────────────────────────────────────────
UNITY_VALIDATE_LLM_PROVIDERS=true

# Communication service URL (for outbound calls, SMS, emails, LiveKit dispatch)
# Required for full E2E testing. CI auto-selects based on branch (main→production, else→staging).
# Staging (for local development):
UNITY_COMMS_URL="https://unity-comms-app-staging-262420637606.us-central1.run.app"
# Production (main branch only):
# UNITY_COMMS_URL="https://unity-comms-app-262420637606.us-central1.run.app"

# Admin key for authenticating Unity → Communication service and Orchestra admin API calls.
# Required for: outbound SMS/email/calls, LiveKit dispatch, spending limits, VM management.
ORCHESTRA_ADMIN_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# LiveKit (Voice Calls)
# ─────────────────────────────────────────────────────────────────────────────
# For local testing: install livekit-server (brew install livekit) and use defaults.
# For cloud testing: use your LiveKit Cloud credentials.

# SIP trunk URI (for Twilio phone calls via LiveKit)
LIVEKIT_SIP_URI=

# LiveKit server URL
# Local dev server: ws://localhost:7880 (auto-started by tests if livekit-server installed)
# Cloud: wss://your-project.livekit.cloud
LIVEKIT_URL=

# LiveKit API credentials
# Local dev: devkey/secret (auto-configured by livekit-server --dev)
# Cloud: from your LiveKit Cloud dashboard
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Third-Party APIs
# ─────────────────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
TAVILY_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# FileManager (Plot API)
# ─────────────────────────────────────────────────────────────────────────────
UNITY_FILE_CONSOLE_BASE_URL="https://console.unify.ai"
UNITY_FILE_PLOT_API_ENDPOINT="/api/plot/create"
UNITY_FILE_PLOT_API_TIMEOUT=30.0
UNITY_FILE_PLOT_API_MAX_RETRIES=3
UNITY_FILE_PLOT_API_RETRY_BACKOFF=1.0
