# Auto-load .env for both main repo and Cursor worktrees
#
# Requires direnv: brew install direnv
# Add to ~/.zshenv: eval "$(direnv hook zsh)"
# Then run: direnv allow

if [[ -f .git ]]; then
  # We're in a git worktree - .git is a file pointing to main repo
  gitdir=$(cat .git | sed 's/gitdir: //')
  main_repo=$(dirname "$(dirname "$(dirname "$gitdir")")")
  [[ -f "$main_repo/.env" ]] && dotenv "$main_repo/.env"
elif [[ -d .git ]] && [[ -f .env ]]; then
  # We're in the main repo
  dotenv .env
fi
