# Unity self-host compose environment.
# Generated by install-compose.sh — edit keys here, then run: unity restart

# --- Secrets (installer-generated on first run) ---
# POSTGRES_PASSWORD, ORCHESTRA_ADMIN_KEY, NEXTAUTH_SECRET, JWT_SECRET,
# INTEGRATION_CONFIRMATION_SECRET
NEXTAUTH_URL=http://127.0.0.1:3000

# --- Console ---
CONSOLE_PORT=3000

# --- BYOK (wizard prompts for these on install) ---
# Chat: at least one LLM key (OpenAI, Anthropic, or DeepSeek).
# OpenAI also powers tool-search embeddings when chat uses another provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# Voice (browser calls): Deepgram + Cartesia
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
# Chat model — the install wizard sets this to match your LLM key.
# Format: <model>@<provider>, e.g. claude-4.6-sonnet@anthropic
UNIFY_MODEL=

# --- Optional ---
UNITY_WEB_TAVILY_API_KEY=
UNITY_WEB_ENABLED=false
ANTICAPTCHA_KEY=
UNITY_ACTOR_ANTICAPTCHA_KEY=
# Composio (https://composio.dev) — third-party app integrations (HubSpot,
# Notion, GitHub, ...). Leave empty to keep the Composio provider disabled.
COMPOSIO_API_KEY=

# --- Workspace bind mount (host path) ---
UNITY_WORKSPACE_HOST=${HOME}/Unity/Local

# --- Pub/Sub emulator ---
PUBSUB_GCP_PROJECT_ID=local-test-project
PUBSUB_TOPIC_SUFFIX=-staging

# --- Image tags (override for local builds) ---
UNITY_IMAGE=ghcr.io/unifyai/unity-selfhost:staging
CONSOLE_IMAGE=ghcr.io/unifyai/console-selfhost:staging
ORCHESTRA_IMAGE=ghcr.io/unifyai/orchestra:staging
DESKTOP_IMAGE=ghcr.io/unifyai/unity-desktop-selfhost:staging

# --- Desktop escape hatch: set to 0 and scale desktop services to 0 ---
UNITY_DESKTOP=1
